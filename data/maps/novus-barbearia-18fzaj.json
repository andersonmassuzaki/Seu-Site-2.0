      "googleMapsUri": "https://www.google.com/maps/reviews/data=!4m6!14m5!1m4!2m3!1sCi9DQUlRQUNvZENodHljRjlvT25oNVoySkVlRGt0ZUhWQmNWUlZSRzFhVW5WTFNHYxAB!2m1!1s0x94ce515b33ebcadd:0xf04b655786c67d36"
